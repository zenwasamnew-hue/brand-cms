# ================================================================
# Supabase 配置 - 复制本文件为 .env.local 并填入真实值
# 获取地址：Supabase 控制台 → Project Settings → API
# ================================================================

# Supabase 项目 URL（公开，可暴露在前端）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥（公开，前端使用，受 RLS 保护）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxx

# Supabase 服务角色密钥（极机密！绝不暴露在前端，只能在服务端使用）
# 该密钥可绕过所有 RLS 策略，相当于数据库管理员
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxx

# 站点 URL（用于邮件回调、SEO 等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
